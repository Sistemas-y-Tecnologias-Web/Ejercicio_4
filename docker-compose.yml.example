services:

    postgres:
     build:
       context: .
       dockerfile: docker/postgres.Dockerfile
     environment:
       POSTGRES_USER: ${DB_USER}
       POSTGRES_PASSWORD: ${DB_PASS}
       POSTGRES_DB: ${DB_NAME}
     ports:
      - "${DB_PORT}:5432"
     volumes:
      - postgres_data:/var/lib/postgresql/data
     healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 5s
      timeout: 5s
      retries: 5

    api:
     build:
      context: .
      dockerfile: docker/api.Dockerfile
     ports:
      - "24484:24484"
     environment:
      DB_USER: ${DB_USER}
      DB_PASS: ${DB_PASS}
      DB_HOST: postgres
      DB_PORT: 5432
      DB_NAME: ${DB_NAME}
     depends_on:
      postgres:
       condition: service_healthy

volumes:
    postgres_data: